    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
